{
  "name": "gui-agent-oversight",
  "description": "Control your browser with natural language",
  "version": "0.1.0",
  "type": "module",
  "keywords": [
    "browser-automation",
    "chrome-extension",
    "natural-language",
    "claude",
    "playwright"
  ],
  "author": "gui-agent-oversight Contributors",
  "repository": {
    "type": "git",
    "url": "https://github.com/CRChenND/gui-agent-oversight.git"
  },
  "scripts": {
    "build": "tsc && vite build && node scripts/copy-static.js",
    "dev": "node scripts/copy-static.js && tsc && node scripts/dev-helper.js && vite build --watch",
    "dev:serve": "vite",
    "copy-static": "node scripts/copy-static.js",
    "test:e2e:runtime": "node scripts/run-runtime-e2e.mjs",
    "lint": "eslint \"src/**/*.{ts,tsx,js,jsx}\"",
    "lint:fix": "eslint \"src/**/*.{ts,tsx,js,jsx}\" --fix"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@fortawesome/fontawesome-svg-core": "^6.7.2",
    "@fortawesome/free-solid-svg-icons": "^6.7.2",
    "@fortawesome/react-fontawesome": "^0.2.2",
    "@google/genai": "^0.9.0",
    "langchain": "^0.3.22",
    "ollama": "^0.5.15",
    "openai": "^4.28.0",
    "playwright-crx": "npm:@parsaghaffari/playwright-crx@0.14.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-markdown": "^10.1.0",
    "react-textarea-autosize": "^8.5.9",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.27.0",
    "@tailwindcss/vite": "^4.1.4",
    "@types/chrome": "^0.0.281",
    "@types/react": "^18.2.66",
    "@types/react-dom": "^18.2.22",
    "@vitejs/plugin-react": "^4.4.0",
    "daisyui": "^5.0.27",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-react": "^7.37.5",
    "rollup-plugin-sourcemaps": "^0.6.3",
    "tailwindcss": "^4.1.4",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.32.1",
    "vite": "^6.1.0"
  }
}
